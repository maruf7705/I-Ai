        {
            "parameters": {
                "jsCode": "const rawResponse = $input.item.json;\nlet aiText = '';\n\nif (typeof rawResponse === 'string') {\n  aiText = rawResponse;\n} else if (typeof rawResponse === 'object' && rawResponse !== null) {\n  aiText = rawResponse.response ||\n           rawResponse.text ||\n           rawResponse.content ||\n           rawResponse.output ||\n           rawResponse.message ||\n           JSON.stringify(rawResponse);\n} else {\n  aiText = 'দুঃখিত, সঠিক উত্তর তৈরি করা যায়নি।';\n}\n\naiText = String(aiText).trim();\nif (!aiText || aiText === 'null' || aiText === '{}') {\n  aiText = 'দুঃখিত, সঠিক উত্তর তৈরি করা যায়নি। অনুগ্রহ করে আবার চেষ্টা করুন।';\n}\n\nreturn { json: { reply: aiText } };"
            },
